# Required: keep this secret and unique.
DB_ENCRYPTION_KEY=change-me-please
# Optional: enables emergency admin password reset without login.
EMERGENCY_RESET_KEY=

# App runtime
PORT=3003
DB_FILE=/data/manga.db

# Backup scheduler (inside manga-tracker container)
BACKUP_ENABLED=true
BACKUP_INTERVAL_MINUTES=1440
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/backups

# Reverse-proxy / security
TRUST_PROXY=true
CSRF_TRUSTED_ORIGINS=https://localhost,https://mangatracker.local
